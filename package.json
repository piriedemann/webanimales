{
  "name": "static-site",
  "version": "1.0.0",
  "description": "Sitio web estático con Markdown",
  "main": "build.js",
  "scripts": {
    "build": "node build.js",
    "watch": "node build.js --watch",
    "serve": "serve public",
    "dev": "npm run build && concurrently \"npm run watch\" \"npm run serve\""
  },
  "dependencies": {
