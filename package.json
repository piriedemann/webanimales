    "front-matter": "^4.0.2",
    "fs-extra": "^11.3.0",
    "gray-matter": "^4.0.3",
    "marked": "^4.3.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "serve": "^14.2.1"
  }
}
